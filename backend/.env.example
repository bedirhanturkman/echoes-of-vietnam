# The Echoing Threshold — Environment Variables Example

# AI Model API Keys
GROQ_API_KEY=gsk_your-groq-key-here
GEMINI_API_KEY=your-gemini-key-here

# App Settings
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
DEFAULT_CHARACTER=bob_dylan_1973

# Historical Context Period
HISTORICAL_PERIOD=1973
OUTPUT_DIR=output

# Feature Flags
USE_MOCK_EMBEDDINGS=false

# Musical Defaults
DEFAULT_SCALE=C_major_pentatonic
DEFAULT_TEMPO=72
DEFAULT_PROGRESSION=knockin_verse
